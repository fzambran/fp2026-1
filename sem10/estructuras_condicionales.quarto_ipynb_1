    "flowchart TD\n",
    "    A([Inicio]) --> B{condición}\n",
    "    B -->|Verdadero| C[Bloque if]\n",
    "    B -->|Falso| D([Continúa])\n",
    "    C --> D\n",
    "    style B fill:#02FF7A,stroke:#000000,color:#000000\n",
    "    style A fill:#000000,stroke:#000000,color:#ffffff\n",
    "    style D fill:#000000,stroke:#000000,color:#ffffff\n",
    "    style C fill:#e6fff2,stroke:#02FF7A,color:#000000\n",
    "```\n",
    "\n",
    ":::\n",
    "::::\n",
    "\n",
